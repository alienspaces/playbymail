{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "http://playbymail.games/schema/turnsheet/mecha/join_game.schema.json",
    "title": "ScannedDataMechaJoinGame",
    "description": "scanned_data shape for turn sheet type mecha_join_game. Captures the player's contact details and commander name from the join game sheet.",
    "type": "object",
    "properties": {
        "email": {
            "type": "string",
            "description": "Player email address."
        },
        "name": {
            "type": "string",
            "description": "Player display name."
        },
        "postal_address_line1": {
            "type": "string",
            "description": "First line of postal address."
        },
        "postal_address_line2": {
            "type": "string",
            "description": "Second line of postal address."
        },
        "state_province": {
            "type": "string",
            "description": "State or province."
        },
        "country": {
            "type": "string",
            "description": "Country."
        },
        "postal_code": {
            "type": "string",
            "description": "Postal or zip code."
        },
        "delivery_method": {
            "type": "string",
            "description": "Chosen delivery method: email, local, or post.",
            "enum": [
                "email",
                "local",
                "post",
                ""
            ]
        },
        "commander_name": {
            "type": "string",
            "description": "Player-chosen commander name for the squad."
        }
    },
    "required": [
        "email",
        "commander_name"
    ],
    "additionalProperties": true
}