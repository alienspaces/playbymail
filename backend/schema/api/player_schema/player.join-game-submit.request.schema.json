{
    "$schema": "http://json-schema.org/draft-07/schema",
    "$id": "http://playbymail.games/schema/player_schema/player.join-game-submit.request.schema.json",
    "title": "JoinGameSubmitRequest",
    "type": "object",
    "properties": {
        "email": {
            "type": "string",
            "format": "email",
            "minLength": 3,
            "maxLength": 255
        },
        "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 255
        },
        "character_name": {
            "type": "string",
            "maxLength": 255
        },
        "postal_address_line1": {
            "type": "string",
            "minLength": 0,
            "maxLength": 255
        },
        "postal_address_line2": {
            "type": "string",
            "maxLength": 255
        },
        "state_province": {
            "type": "string",
            "minLength": 0,
            "maxLength": 255
        },
        "country": {
            "type": "string",
            "minLength": 0,
            "maxLength": 255
        },
        "postal_code": {
            "type": "string",
            "minLength": 0,
            "maxLength": 20
        },
        "delivery_method": {
            "type": "string",
            "enum": ["email", "local", "post"]
        }
    },
    "required": [
        "email",
        "name",
        "delivery_method"
    ],
    "additionalProperties": false
}
