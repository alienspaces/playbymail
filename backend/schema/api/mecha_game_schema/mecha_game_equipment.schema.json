{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "http://playbymail.games/schema/mecha_game_schema/mecha_game_equipment.schema.json",
    "title": "MechaGameEquipment",
    "type": "object",
    "properties": {
        "id": {
            "$ref": "http://playbymail.games/schema/common_schema/common.schema.json#/$defs/id"
        },
        "game_id": {
            "$ref": "http://playbymail.games/schema/common_schema/common.schema.json#/$defs/id"
        },
        "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
        },
        "description": {
            "type": "string"
        },
        "mount_size": {
            "type": "string",
            "enum": ["small", "medium", "large"]
        },
        "effect_kind": {
            "type": "string",
            "enum": ["heat_sink", "targeting_computer", "armor_upgrade", "jump_jets", "ecm", "ammo_bin"]
        },
        "magnitude": {
            "type": "integer"
        },
        "heat_cost": {
            "type": "integer"
        },
        "created_at": {
            "$ref": "http://playbymail.games/schema/common_schema/common.schema.json#/$defs/created_at"
        },
        "updated_at": {
            "$ref": "http://playbymail.games/schema/common_schema/common.schema.json#/$defs/updated_at"
        },
        "deleted_at": {
            "$ref": "http://playbymail.games/schema/common_schema/common.schema.json#/$defs/updated_at"
        }
    },
    "required": ["id", "game_id", "name", "description", "mount_size", "effect_kind", "magnitude", "heat_cost", "created_at"],
    "additionalProperties": false
}
