{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "http://playbymail.games/schema/mecha_game_schema/mecha_game_squad.request.schema.json",
    "title": "MechaGameSquadRequest",
    "type": "object",
    "properties": {
        "squad_type": {
            "type": "string",
            "enum": ["starter", "opponent"]
        },
        "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
        },
        "description": {
            "type": "string"
        }
    },
    "required": ["squad_type", "name", "description"],
    "additionalProperties": false
}
