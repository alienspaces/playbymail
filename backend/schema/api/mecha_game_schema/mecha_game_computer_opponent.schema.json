{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "http://playbymail.games/schema/mecha_game_schema/mecha_game_computer_opponent.schema.json",
    "title": "MechaGameComputerOpponent",
    "type": "object",
