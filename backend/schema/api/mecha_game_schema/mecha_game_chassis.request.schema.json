{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "http://playbymail.games/schema/mecha_game_schema/mecha_game_chassis.request.schema.json",
    "title": "MechaGameChassisRequest",
    "type": "object",
    "properties": {
        "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
        },
        "description": {
            "type": "string"
        },
        "chassis_class": {
            "type": "string",
            "enum": ["light", "medium", "heavy", "assault"]
        },
        "armor_points": {
            "type": "integer"
        },
        "structure_points": {
            "type": "integer"
        },
        "heat_capacity": {
            "type": "integer"
        },
        "speed": {
            "type": "integer"
        }
    },
    "required": ["name", "description"],
    "additionalProperties": false
}
