{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "http://playbymail.games/schema/mecha_game_schema/mecha_game_computer_opponent.request.schema.json",
    "title": "MechaGameComputerOpponentRequest",
    "type": "object",
    "properties": {
        "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
        },
        "description": {
            "type": "string"
        },
        "aggression": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
        },
        "iq": {
            "type": "integer",
            "minimum": 1,
            "maximum": 10
        }
    },
    "required": [
        "name",
        "description"
    ],
    "additionalProperties": false
}