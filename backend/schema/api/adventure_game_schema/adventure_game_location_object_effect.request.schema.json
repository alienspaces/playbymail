{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "http://playbymail.games/schema/adventure_game_schema/adventure_game_location_object_effect.request.schema.json",
    "title": "AdventureGameLocationObjectEffectRequest",
    "type": "object",
