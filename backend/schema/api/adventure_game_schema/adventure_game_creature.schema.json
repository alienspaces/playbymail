{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "http://playbymail.games/schema/adventure_game_schema/adventure_game_creature.schema.json",
    "title": "AdventureGameCreature",
    "type": "object",
    "properties": {
        "created_at": {
            "$ref": "http://playbymail.games/schema/common_schema/common.schema.json#/$defs/created_at"
        },
        "deleted_at": {
            "$ref": "http://playbymail.games/schema/common_schema/common.schema.json#/$defs/updated_at"
        },
        "description": {
            "type": "string"
        },
        "game_id": {
            "$ref": "http://playbymail.games/schema/common_schema/common.schema.json#/$defs/id"
        },
        "id": {
            "$ref": "http://playbymail.games/schema/common_schema/common.schema.json#/$defs/id"
        },
        "name": {
            "maxLength": 255,
            "minLength": 1,
            "type": "string"
        },
        "updated_at": {
            "$ref": "http://playbymail.games/schema/common_schema/common.schema.json#/$defs/updated_at"
        },
        "attack_damage": {
            "type": "integer"
        },
        "defense": {
            "type": "integer"
        },
        "max_health": {
            "type": "integer"
        },
        "disposition": {
            "type": "string",
            "enum": ["aggressive", "inquisitive", "indifferent"]
        },
        "attack_method": {
            "type": "string",
            "enum": ["claws", "bite", "sting", "weapon", "spell", "slam", "touch", "breath", "gaze"]
        },
        "attack_description": {
            "type": "string"
        },
        "body_decay_turns": {
            "type": "integer"
        },
        "respawn_turns": {
            "type": "integer"
        }
    },
    "required": [
        "id",
        "game_id",
        "name",
        "description",
        "attack_damage",
        "defense",
        "max_health",
        "disposition",
        "attack_method",
        "attack_description",
        "body_decay_turns",
        "respawn_turns",
        "created_at"
    ],
    "additionalProperties": false
}
