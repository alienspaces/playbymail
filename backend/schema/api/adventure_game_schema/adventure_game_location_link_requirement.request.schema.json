{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "http://playbymail.games/schema/adventure_game_schema/adventure_game_location_link_requirement.request.schema.json",
    "title": "AdventureGameLocationLinkRequirementRequest",
    "type": "object",
    "properties": {
        "game_location_link_id": {
            "$ref": "http://playbymail.games/schema/common_schema/common.schema.json#/$defs/id"
        },
        "game_item_id": {
            "$ref": "http://playbymail.games/schema/common_schema/common.schema.json#/$defs/id"
        },
        "game_creature_id": {
            "$ref": "http://playbymail.games/schema/common_schema/common.schema.json#/$defs/id"
        },
        "purpose": {
            "type": "string",
            "enum": [
                "traverse",
                "visible"
            ]
        },
        "condition": {
            "type": "string",
            "enum": [
                "in_inventory",
                "equipped",
                "dead_at_location",
                "none_alive_at_location",
                "none_alive_in_game"
            ]
        },
        "quantity": {
            "minimum": 1,
            "type": "integer"
        }
    },
    "required": [
        "game_location_link_id",
        "purpose",
        "condition",
        "quantity"
    ],
    "additionalProperties": false
}