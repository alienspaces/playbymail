{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "http://playbymail.games/schema/adventure_game_schema/adventure_game_creature.request.schema.json",
    "title": "AdventureGameCreatureRequest",
    "type": "object",
    "properties": {
        "description": {
            "type": "string"
        },
        "name": {
            "maxLength": 255,
            "minLength": 1,
            "type": "string"
        },
        "attack_damage": {
            "type": "integer"
        },
        "defense": {
            "type": "integer"
        },
        "max_health": {
            "type": "integer"
        },
        "disposition": {
            "type": "string",
            "enum": ["aggressive", "inquisitive", "indifferent"]
        },
        "attack_method": {
            "type": "string",
            "enum": ["claws", "bite", "sting", "weapon", "spell", "slam", "touch", "breath", "gaze"]
        },
        "attack_description": {
            "type": "string"
        },
        "body_decay_turns": {
            "type": "integer"
        },
        "respawn_turns": {
            "type": "integer"
        }
    },
    "required": [
        "name",
        "description"
    ],
    "additionalProperties": false
}
