{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "http://playbymail.games/schema/mecha_schema/mecha_sector.schema.json",
    "title": "MechaSector",
    "type": "object",
    "properties": {
        "id": {
            "$ref": "http://playbymail.games/schema/common_schema/common.schema.json#/$defs/id"
        },
        "game_id": {
            "$ref": "http://playbymail.games/schema/common_schema/common.schema.json#/$defs/id"
        },
        "name": {
            "type": "string",
            "minLength": 1,
            "maxLength": 100
        },
        "description": {
            "type": "string"
        },
        "terrain_type": {
            "type": "string",
            "enum": ["open", "rough", "forest", "urban", "water"]
        },
        "elevation": {
            "type": "integer"
        },
        "is_starting_sector": {
            "type": "boolean"
        },
        "created_at": {
            "$ref": "http://playbymail.games/schema/common_schema/common.schema.json#/$defs/created_at"
        },
        "updated_at": {
            "$ref": "http://playbymail.games/schema/common_schema/common.schema.json#/$defs/updated_at"
        },
        "deleted_at": {
            "$ref": "http://playbymail.games/schema/common_schema/common.schema.json#/$defs/updated_at"
        }
    },
    "required": ["id", "game_id", "name", "description", "terrain_type", "elevation", "is_starting_sector", "created_at"],
    "additionalProperties": false
}
