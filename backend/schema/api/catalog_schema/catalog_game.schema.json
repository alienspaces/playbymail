{
    "$schema": "http://json-schema.org/draft-07/schema",
    "$id": "http://playbymail.games/schema/catalog_schema/catalog_game.schema.json",
    "title": "CatalogSubscription",
    "type": "object",
    "properties": {
        "game_subscription_id": {
            "$ref": "http://playbymail.games/schema/common_schema/common.schema.json#/$defs/id"
        },
        "game_name": {
            "description": "The name of the game.",
            "type": "string",
            "minLength": 1,
            "maxLength": 1024
        },
        "game_description": {
            "description": "Game description.",
            "type": "string",
            "minLength": 0,
            "maxLength": 512
        },
        "game_type": {
            "description": "The type of the game.",
            "type": "string",
            "enum": ["adventure"]
        },
        "turn_duration_hours": {
            "description": "Duration of each turn in hours.",
            "type": "integer",
            "minimum": 1
        },
        "total_capacity": {
            "description": "Total required player count across all available instances.",
            "type": "integer",
            "minimum": 0
        },
        "total_players": {
            "description": "Total current player count across all available instances.",
            "type": "integer",
            "minimum": 0
        },
        "delivery_physical_post": {
            "type": "boolean"
        },
        "delivery_physical_local": {
            "type": "boolean"
        },
        "delivery_email": {
            "type": "boolean"
        }
    },
    "required": ["game_subscription_id", "game_name", "game_description", "game_type", "turn_duration_hours", "total_capacity", "total_players", "delivery_physical_post", "delivery_physical_local", "delivery_email"],
    "additionalProperties": false
}
