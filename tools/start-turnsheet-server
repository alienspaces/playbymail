#!/usr/bin/env sh

# Serve the turn sheet gallery with hot reload on template changes.
#
# Starts the Go dev server which:
#   - Renders all turn sheet types to HTML instantly (no DB or Chrome required)
#   - Serves the gallery and individual HTML files
#   - Watches backend/templates/turnsheet/ for changes and auto-reloads the browser
#
# Usage (from playbymail/):
#   ./tools/start-turnsheet-server [port]
#
# Defaults to port 8090. Open the gallery at:
#   http://localhost:8090/gallery.html
#
# The same fixture data is used by TestRenderAllSheets for automated rendering tests.
# Run ./tools/render-turnsheets to also generate PDF fixtures.

set -e

PORT="${1:-8090}"

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

cd "$ROOT"

"$SCRIPT_DIR/stop-turnsheet-server" "$PORT"

echo
echo "=> Starting turn sheet dev server at http://localhost:${PORT}/gallery.html"
echo "=> Edit any .template file to auto-reload the browser"
echo "=> Press Ctrl+C to stop"
echo

cd backend && go run ./cmd/turnsheet-dev/main.go --port "${PORT}"
