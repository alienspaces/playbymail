#!/usr/bin/env sh

# Local Playwright test runner. Run from project root: ./tools/test-playwright
#
# Sets up everything needed and runs the tests in one command:
#   - Database (Docker + migrations + seed data)
#   - Backend (build + start)
#   - Frontend dev server (npm install + start)
#   - MailPit (Docker SMTP catcher for email adventure tests)
#   - Playwright browsers (install if missing)
#
# Services are left running after tests. Use ./tools/stop to clean up.
# For CI, use ./tools/test-playwright-ci instead.
#
# Usage:
#   ./tools/test-playwright                    # Run all tests (chromium)
#   ./tools/test-playwright --ui               # Interactive Playwright UI
#   ./tools/test-playwright --headed           # Visible browser
#   ./tools/test-playwright --grep 'auth'      # Filter by test name
#   ./tools/test-playwright playwright/core/   # Run one directory

set -e

if [ -n "$CI" ]; then
    echo "❌ This script is for local development. Use ./tools/test-playwright-ci in CI."
    exit 1
fi

script_dir="$(dirname "$0")"
cd "$script_dir/.."

# ── Help ──────────────────────────────────────────────────────────────
case "${1:-}" in
    --help|-h)
        sed -n '2,/^[^#]/s/^# \{0,1\}//p' "$0"
        exit 0
        ;;
esac

# ── Environment ───────────────────────────────────────────────────────
if [ -f ".env.e2e" ]; then
    cp .env.e2e .env
elif [ -f ".env.develop" ]; then
    cp .env.develop .env
fi

. "$script_dir/environment" || exit $?

# Re-apply E2E overrides that .env.private may have clobbered
export EMAILER_PROVIDER=smtp
export GAME_TURN_QUEUEING_INTERVAL_SECONDS=10

if [ -z "$TEST_BYPASS_HEADER_NAME" ]; then
    echo "❌ TEST_BYPASS_HEADER_NAME is not set (check .env.develop)"
    exit 1
fi
if [ -z "$TEST_BYPASS_HEADER_VALUE" ]; then
    echo "❌ TEST_BYPASS_HEADER_VALUE is not set (check .env.develop)"
    exit 1
fi

# ── Database ──────────────────────────────────────────────────────────
echo ""
echo "📦 Setting up database..."
./tools/db-setup || { echo "❌ Database setup failed"; exit 1; }
echo "✅ Database ready"

# ── MailPit (must start before backend — backend needs SMTP on port 1025) ─
echo ""
echo "📬 Starting MailPit..."
./tools/mailpit-start 2>/dev/null || echo "⚠️  MailPit start failed (email adventure tests may be skipped)"

# ── Backend ───────────────────────────────────────────────────────────
echo ""
echo "🔨 Building backend..."
(cd backend && go build -o ../playbymail-server ./cmd/server) || { echo "❌ Backend build failed"; exit 1; }
echo "✅ Backend built"

# Always restart backend so it picks up the E2E environment
if [ -f backend/.backend.pid ]; then
    OLD_PID=$(cat backend/.backend.pid)
    if kill -0 "$OLD_PID" 2>/dev/null; then
        echo "🔄 Stopping existing backend (PID: $OLD_PID) to apply E2E config..."
        kill "$OLD_PID" 2>/dev/null
        sleep 2
        kill -0 "$OLD_PID" 2>/dev/null && kill -9 "$OLD_PID" 2>/dev/null
    fi
    rm -f backend/.backend.pid
fi
# Kill anything else on port 8080
PORT_PIDS=$(lsof -ti:8080 2>/dev/null || true)
if [ -n "$PORT_PIDS" ]; then
    echo "🔄 Killing stale processes on port 8080: $PORT_PIDS"
    for pid in $PORT_PIDS; do kill -9 "$pid" 2>/dev/null; done
    sleep 1
fi

echo "🚀 Starting backend with E2E config..."
./playbymail-server &
BACKEND_PID=$!
echo "$BACKEND_PID" > backend/.backend.pid
sleep 2
if ! kill -0 "$BACKEND_PID" 2>/dev/null; then
    echo "❌ Backend failed to start"
    exit 1
fi
echo "✅ Backend started (PID: $BACKEND_PID, EMAILER_PROVIDER=$EMAILER_PROVIDER)"

# ── Frontend ──────────────────────────────────────────────────────────
echo ""
if curl -s http://localhost:3000 >/dev/null 2>&1; then
    echo "✅ Frontend dev server already running"
else
    echo "📦 Preparing frontend..."
    if [ ! -d "frontend/node_modules" ] || [ "frontend/package-lock.json" -nt "frontend/node_modules/.package-lock.json" ]; then
        (cd frontend && npm ci --prefer-offline) || { echo "❌ Frontend npm install failed"; exit 1; }
    fi
    echo "🚀 Starting frontend dev server..."
    (cd frontend && npm run dev) &
    FRONTEND_PID=$!
    echo "$FRONTEND_PID" > frontend/.frontend.pid
    echo "✅ Frontend dev server starting (PID: $FRONTEND_PID)"
fi

# ── Playwright browsers ──────────────────────────────────────────────
echo ""
if ls "$HOME/.cache/ms-playwright/chromium-"* >/dev/null 2>&1; then
    echo "✅ Playwright browsers installed"
else
    echo "📦 Installing Playwright browsers..."
    npx playwright install chromium --with-deps
fi

# ── Wait for services ────────────────────────────────────────────────
echo ""
echo "⏳ Waiting for services..."
npx wait-on \
    http-get://localhost:8080/healthz \
    http-get://localhost:3000 \
    --timeout 60000 || { echo "❌ Services did not become healthy in time"; exit 1; }
echo "✅ All services healthy"

# ── Run tests ─────────────────────────────────────────────────────────
if [ $# -eq 0 ]; then
    set -- --project chromium
fi

echo ""
echo "💡 Tip: E2E config comes from .env.e2e (falls back to .env.develop)."
echo "   Current LOG_LEVEL: ${LOG_LEVEL:-not set}"
echo ""
echo "🚀 Running E2E tests..."
echo "Command: npx playwright test $*"
echo ""

exec npx playwright test "$@"
