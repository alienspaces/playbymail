#!/bin/sh

if [ "${CI:-}" != "" ]; then
    echo "This script is not meant to be run in CI"
    exit 1
fi

# environment
. ./tools/environment || exit $?

# stop any existing mailpit container
. ./tools/mailpit-stop || exit $?

echo "=> (mailpit-start) Starting MailPit - SMTP on 1025, REST API on 8025"

docker run --name "${PROJECT_NAME}-mailpit" \
    -p 1025:1025 \
    -p 8025:8025 \
    -d axllent/mailpit || exit $?

echo "=> (mailpit-start) MailPit running"
echo "   SMTP:     localhost:1025"
echo "   Web UI:   http://localhost:8025"
echo "   REST API: http://localhost:8025/api/v1/"
