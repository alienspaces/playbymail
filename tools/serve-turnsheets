#!/usr/bin/env sh

# Serve turn sheet testdata for visual assessment.
#
# Starts a local HTTP server on the testdata directory so the gallery and
# individual turn sheet HTML files can be opened in a browser.
#
# Usage (from playbymail/):
#   ./tools/serve-turnsheets [port]
#
# Defaults to port 8090. Open the gallery at:
#   http://localhost:8090/gallery.html
#
# Run ./tools/render-turnsheets first to generate the HTML fixtures.

PORT="${1:-8090}"
DIR="backend/internal/turnsheet/testdata"

if [ ! -d "$DIR" ]; then
    echo "=> Error: testdata directory not found: $DIR"
    exit 1
fi

echo
echo "=> Serving turn sheets at http://localhost:${PORT}/gallery.html"
echo "=> Press Ctrl+C to stop"
echo

python3 -m http.server "$PORT" --directory "$DIR"
